# ─────────────────────────────────────────────────────────────────────────────
# .env.local — LOCAL DEVELOPMENT ONLY (DO NOT COMMIT)
#
# Copy this to .env.local and fill in your own values for local dev.
# When AZURE_KEY_VAULT_URL is set, secrets are pulled from the vault; otherwise
# the .env file is used as a fallback.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure Key Vault (required for accessing vault secrets) ───────────────────
# This enables DefaultAzureCredential to authenticate via service principal
AZURE_KEY_VAULT_URL=https://mailmind-vault.vault.azure.net/
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret
AZURE_TENANT_ID=common

# ── Non-sensitive config (safe to keep in .env) ────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
APP_ENV=development
APP_RELEASE=mailmind@2.0.0

# Queue backend
QUEUE_BACKEND=memory
# For Redis locally: docker compose -f docker-compose.yml -f docker-compose.scale.yml up
# QUEUE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# Observability
METRICS_ENABLED=true
AUDIT_LOG_ENABLED=true

# Pipeline config
SLA_TRIAGE_SECONDS=1.5
SLA_ENRICHMENT_SECONDS=10.0
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_MAX_RETRIES=3

# Graph API
USE_MOCK_GRAPH=false  # Set to true for mock Graph (no auth needed)
GRAPH_SCOPES=https://graph.microsoft.com/.default
AZURE_TENANT_ID=common

# Azure OpenAI
AZURE_OPENAI_CHAT_DEPLOYMENT=mailmind-gpt
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_LANGUAGE_ENDPOINT=https://mailmind-language.cognitiveservices.azure.com/

# Google OAuth
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# ChromaDB / RAG
USE_CHROMA=true
CHROMA_DATA_PATH=./data/chroma
RAG_SIMILARITY_THRESHOLD=0.78

# App
RATE_LIMIT_PER_MINUTE=100

# Langsmith (optional, for tracing)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=mailmind

# ─────────────────────────────────────────────────────────────────────────────
# SENSITIVE SECRETS BELOW — Pulled from Key Vault when AZURE_KEY_VAULT_URL is set
# (Leave blank locally; DefaultAzureCredential will fetch them from the vault)
#
# If Key Vault is unavailable, you can paste them here as a fallback, but NEVER
# commit them to git!
# ─────────────────────────────────────────────────────────────────────────────

# Database (from vault, or paste here for offline mode)
DATABASE_URL=
SUPABASE_DB_PASSWORD=

# Microsoft Graph (from vault)
AZURE_CLIENT_ID=  # NOTE: for Key Vault auth, not Graph — Graph creds come from vault
AZURE_CLIENT_SECRET=

# Azure OpenAI (from vault)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_LANGUAGE_KEY=

# Google OAuth (from vault)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MailMind (from vault)
APPROVAL_TOKEN=

# Langsmith (from vault)
LANGSMITH_API_KEY=
