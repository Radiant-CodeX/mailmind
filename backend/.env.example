# ─────────────────────────────────────────────────────────────────────────────
# MailMind — environment variable reference
# Copy this to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# Get the connection string from Supabase Dashboard → Settings → Database.
# Use the "Connection string" (postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres)
# Append ?sslmode=require for production.
DATABASE_URL=postgresql://postgres:your_password@db.your_ref.supabase.co:5432/postgres?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Queue backend ─────────────────────────────────────────────────────────────
# "memory" → zero deps, single-process (dev/demo)
# "redis"  → durable, multi-worker (staging/production)
QUEUE_BACKEND=memory
# QUEUE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0

# ── SLA targets (seconds) ─────────────────────────────────────────────────────
SLA_TRIAGE_SECONDS=1.5
SLA_ENRICHMENT_SECONDS=10.0

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
APP_ENV=development          # development | staging | production
APP_RELEASE=mailmind@2.0.0
# SENTRY_DSN=https://...

# ── Compliance / data governance ─────────────────────────────────────────────
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true

# ── Microsoft Graph ───────────────────────────────────────────────────────────
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
GRAPH_SCOPES=https://graph.microsoft.com/.default
USE_MOCK_GRAPH=true

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── Google / Gmail OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── App config ────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
APPROVAL_TOKEN=change-this-in-production
USE_CHROMA=true
RATE_LIMIT_PER_MINUTE=100
