# Azure production profile
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
GRAPH_SCOPES=https://graph.microsoft.com/.default
# Redirect URI for the Microsoft sign-in popup — must be registered in the app
# registration (Authentication → Web platform).
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback
USE_MOCK_GRAPH=true

# Endpoint must be the BASE url only (https://<resource>.openai.azure.com/).
# A full /openai/deployments/.../chat/completions path is auto-normalised, but keep it clean.
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

FRONTEND_ORIGIN=https://your-production-domain.com
APPROVAL_TOKEN=generate-a-strong-secret-here
USE_CHROMA=false
AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_AI_SEARCH_KEY=your_search_key
AZURE_AI_SEARCH_INDEX_NAME=mailmind-rag

# Google / Gmail OAuth (see GOOGLE_SETUP.md). Leave blank to keep Gmail in mock mode.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Azure Key Vault (optional). When set, secrets are pulled from the vault and
# override .env. Secret names map by replacing '-' with '_' and upper-casing,
# e.g. vault secret AZURE-OPENAI-API-KEY -> env AZURE_OPENAI_API_KEY.
AZURE_KEY_VAULT_URL=

# Error tracking (optional — leave blank to disable Sentry)
SENTRY_DSN=
APP_ENV=production
