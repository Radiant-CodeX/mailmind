# ── Database (Supabase / PostgreSQL) ─────────────────────────────────────────
# For docker-compose (containers can reach IPv4 pooler), use SUPABASE_DB_PASSWORD:
SUPABASE_DB_PASSWORD=
# Using the MailMind Supabase project (ap-south-1, ACTIVE_HEALTHY)
# Connect via the Postgres connection string (service_role — bypasses RLS).
# Use ?sslmode=require for production TLS enforcement.
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Queue backend ─────────────────────────────────────────────────────────────
# "memory" for local dev (zero deps), "redis" for staging/production.
QUEUE_BACKEND=memory
# QUEUE_BACKEND=redis
# REDIS_URL=redis://localhost:6379/0
QUEUE_ENRICHMENT_KEY=mailmind:queue:enrichment

# ── Worker settings ───────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY_SECONDS=30

# ── SLA targets (seconds) ─────────────────────────────────────────────────────
SLA_TRIAGE_SECONDS=1.5
SLA_ENRICHMENT_SECONDS=10.0

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
APP_ENV=development
APP_RELEASE=mailmind@2.0.0

# ── Compliance / data governance ─────────────────────────────────────────────
DATA_RETENTION_DAYS=90
AUDIT_LOG_ENABLED=true

# Microsoft Graph
AZURE_TENANT_ID=common
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default
USE_MOCK_GRAPH=false

# Azure Vault
AZURE_KEY_VAULT_URL=https://mailmind-vault.vault.azure.net/

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=mailmind-gpt
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_LANGUAGE_KEY=
AZURE_LANGUAGE_ENDPOINT=

# Google / Gmail OAuth (fill these from Google Cloud Console — see GOOGLE_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Groq fallback LLM (when Azure OpenAI is not configured)
GROQ_API_KEY=

# App config
FRONTEND_ORIGIN=http://localhost:3000
APPROVAL_TOKEN=
USE_CHROMA=true
RATE_LIMIT_PER_MINUTE=100

# Langsmith
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=mailmind